# TransitOps — Supabase config
# Copy this file to ".env.local" and fill in your values.
# Find these in your Supabase Dashboard → Settings → API
#
# NOTE: for the direct-from-frontend setup we use the PROJECT URL + ANON key,
#       NOT the Postgres connection string. The anon key is safe to expose in
#       the browser because Row Level Security (RLS) protects your data.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
